---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import { projects } from '../data/projects';
import { siteMeta } from '../data/site';
import { withBase } from '../utils/paths';

interface Props {
  title?: string;
  active?: 'home' | 'articles' | 'projects' | 'search';
  description?: string;
}

const {
  title = siteMeta.siteName,
  active = 'home',
  description = siteMeta.siteDescription,
} = Astro.props;

const pageTitle = title === siteMeta.siteName ? title : `${title} | ${siteMeta.siteName}`;

const posts = (await getCollection('posts'))
  .filter((post) => !post.data.draft && !post.data.private)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const searchItems = [
  ...posts.map((post) => ({
    type: '文章',
    title: post.data.title,
    description: post.data.description,
    href: withBase(`/articles/${post.slug}/`),
    keywords: [post.data.category, ...post.data.tags],
  })),
  ...projects.map((project) => ({
    type: '项目',
    title: project.title,
    description: project.description,
    href: project.url ?? withBase('/projects/'),
    keywords: [project.type, ...project.tags],
  })),
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <script is:inline>
      (function () {
        try {
          var savedTheme = localStorage.getItem('theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          document.documentElement.dataset.theme = savedTheme || (prefersDark ? 'dark' : 'light');
        } catch (error) {
          document.documentElement.dataset.theme = 'light';
        }
      })();
    </script>
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="brand" href={withBase('/')} aria-label={`${siteMeta.siteName} 首页`}>
          <span class="brand-mark">C</span>
          <span>{siteMeta.siteName}</span>
        </a>
        <nav class="site-nav" aria-label="主导航">
          <a class:list={[active === 'home' && 'active']} href={withBase('/')}>首页</a>
          <a class:list={[active === 'articles' && 'active']} href={withBase('/articles/')}>文章</a>
          <a class:list={[active === 'projects' && 'active']} href={withBase('/projects/')}>项目</a>
          <div class:list={['nav-search', active === 'search' && 'active']} data-site-search data-search-items={JSON.stringify(searchItems)}>
            <button class="nav-search-trigger" type="button" aria-label="搜索文章和项目" aria-expanded="false" data-search-toggle>搜索</button>
            <div class="nav-search-panel">
              <input data-search-input type="search" placeholder="搜索文章 / 项目" autocomplete="off" aria-label="搜索文章和项目" />
              <div class="nav-search-results" data-search-results aria-live="polite"></div>
            </div>
          </div>
          <a href={withBase(siteMeta.rssPath)}>RSS</a>
          <a href={withBase('/about/')}>关于</a>
        </nav>
        <button class="theme-button" type="button" aria-label="切换到深色主题" data-theme-toggle>◐</button>
      </header>
      <div data-pagefind-body>
        <slot />
      </div>
    </div>
    <script is:inline>
      (function () {
        var button = document.querySelector('[data-theme-toggle]');
        if (!button) return;

        function currentTheme() {
          return document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
        }

        function updateButton(theme) {
          button.textContent = theme === 'dark' ? '☀' : '◐';
          button.setAttribute('aria-label', theme === 'dark' ? '切换到浅色主题' : '切换到深色主题');
        }

        updateButton(currentTheme());
        button.addEventListener('click', function () {
          var nextTheme = currentTheme() === 'dark' ? 'light' : 'dark';
          document.documentElement.dataset.theme = nextTheme;
          updateButton(nextTheme);
          try {
            localStorage.setItem('theme', nextTheme);
          } catch (error) {}
        });
      })();
    </script>
    <script is:inline>
      (function () {
        var search = document.querySelector('[data-site-search]');
        if (!search) return;

        var toggle = search.querySelector('[data-search-toggle]');
        var input = search.querySelector('[data-search-input]');
        var results = search.querySelector('[data-search-results]');
        var items = [];

        try {
          items = JSON.parse(search.getAttribute('data-search-items') || '[]');
        } catch (error) {}

        function itemText(item) {
          return [item.title, item.description].concat(item.keywords || []).join(' ').toLowerCase();
        }

        function escapeHtml(value) {
          return String(value)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
        }

        function setOpen(isOpen) {
          search.classList.toggle('open', isOpen);
          toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        }

        function render(query) {
          var normalizedQuery = query.trim().toLowerCase();
          var matches = items
            .filter(function (item) {
              return !normalizedQuery || itemText(item).includes(normalizedQuery);
            })
            .slice(0, 6);

          if (!matches.length) {
            results.innerHTML = '<p class="nav-search-empty">没有找到匹配内容</p>';
            return;
          }

          results.innerHTML = matches.map(function (item) {
            return [
              '<a class="nav-search-result" href="' + escapeHtml(item.href) + '">',
              '<span>' + escapeHtml(item.type) + '</span>',
              '<b>' + escapeHtml(item.title) + '</b>',
              '<small>' + escapeHtml(item.description) + '</small>',
              '</a>',
            ].join('');
          }).join('');
        }

        render('');

        toggle.addEventListener('click', function () {
          setOpen(true);
          input.focus();
        });

        input.addEventListener('focus', function () {
          setOpen(true);
        });

        input.addEventListener('input', function () {
          render(input.value);
        });

        document.addEventListener('keydown', function (event) {
          if (event.key === 'Escape') {
            setOpen(false);
            input.blur();
          }
        });

        document.addEventListener('click', function (event) {
          if (!search.contains(event.target)) {
            setOpen(false);
          }
        });
      })();
    </script>
  </body>
</html>
