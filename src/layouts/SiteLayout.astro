---
import '../styles/global.css';
import { siteMeta } from '../data/site';

interface Props {
  title?: string;
  active?: 'home' | 'articles' | 'projects' | 'guides' | 'search';
  description?: string;
}

const {
  title = siteMeta.siteName,
  active = 'home',
  description = siteMeta.siteDescription,
} = Astro.props;

const pageTitle = title === siteMeta.siteName ? title : `${title} | ${siteMeta.siteName}`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="brand" href="/" aria-label={`${siteMeta.siteName} 首页`}>
          <span class="brand-mark">C</span>
          <span>{siteMeta.siteName}</span>
        </a>
        <nav class="site-nav" aria-label="主导航">
          <a class:list={[active === 'home' && 'active']} href="/">首页</a>
          <a class:list={[active === 'articles' && 'active']} href="/articles/">AI / Agent</a>
          <a href="/articles/">RPA</a>
          <a class:list={[active === 'search' && 'active']} href="/search/">搜索</a>
          <a class:list={[active === 'projects' && 'active']} href="/projects/">项目</a>
          <a class:list={[active === 'guides' && 'active']} href="/guides/mdx-content/">指南</a>
          <a href="/about/">关于</a>
          <a href={siteMeta.rssPath}>RSS</a>
        </nav>
        <button class="theme-button" type="button" aria-label="主题切换占位">◐</button>
      </header>
      <div data-pagefind-body>
        <slot />
      </div>
    </div>
  </body>
</html>
