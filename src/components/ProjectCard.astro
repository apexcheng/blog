---
interface Project {
  title: string;
  type: string;
  description: string;
  tags: string[];
  tone: string;
  url?: string;
}

interface Props {
  project: Project;
  index: number;
}

const { project, index } = Astro.props;
const number = String(index + 1).padStart(2, '0');
---

<article class="project-card">
  <div class:list={['project-cover', `tone-${project.tone}`]}>
    <span>{project.type}</span>
    <b>{number}</b>
  </div>
  <div class="project-body">
    <h3>{project.title}</h3>
    <p>{project.description}</p>
    <div class="chips">
      {project.tags.map((tag) => <span>{tag}</span>)}
    </div>
    {project.url && <a class="project-link" href={project.url}>查看项目</a>}
  </div>
</article>
