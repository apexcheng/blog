---
interface Props {
  label: string;
  value: string;
  detail?: string;
  tone?: 'blue' | 'cyan' | 'violet' | 'green';
}

const { label, value, detail, tone = 'blue' } = Astro.props;
---

<article class={`metric-card tone-${tone}`}>
  <span>{label}</span>
  <strong>{value}</strong>
  {detail && <p>{detail}</p>}
</article>

<style>
  .metric-card {
    background:
      linear-gradient(var(--paper), var(--paper)) padding-box,
      linear-gradient(135deg, rgba(37, 99, 235, 0.72), rgba(14, 116, 144, 0.2)) border-box;
    border: 1px solid transparent;
    border-radius: var(--radius);
    min-height: 148px;
    padding: 22px;
  }

  .metric-card span {
    color: var(--muted);
    display: block;
    font-size: 13px;
    font-weight: 760;
    margin-bottom: 14px;
  }

  .metric-card strong {
    color: var(--ink);
    display: block;
    font-size: 34px;
    line-height: 1.08;
  }

  .metric-card p {
    color: var(--soft);
    font-size: 14px;
    margin: 14px 0 0;
  }

  .tone-cyan {
    background:
      linear-gradient(var(--paper), var(--paper)) padding-box,
      linear-gradient(135deg, rgba(14, 116, 144, 0.72), rgba(94, 234, 212, 0.22)) border-box;
  }

  .tone-violet {
    background:
      linear-gradient(var(--paper), var(--paper)) padding-box,
      linear-gradient(135deg, rgba(109, 40, 217, 0.72), rgba(37, 99, 235, 0.22)) border-box;
  }

  .tone-green {
    background:
      linear-gradient(var(--paper), var(--paper)) padding-box,
      linear-gradient(135deg, rgba(15, 118, 110, 0.72), rgba(34, 197, 94, 0.2)) border-box;
  }
</style>
