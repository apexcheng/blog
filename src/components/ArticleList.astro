---
import { withBase } from '../utils/paths';

const { posts } = Astro.props;
---

<div class="article-list">
  {posts.map((post) => (
    <article class="article-list-item">
      <div>
        <small><a href={withBase(`/articles/category/${encodeURIComponent(post.data.category)}/`)}>{post.data.category}</a></small>
        <h2><a href={withBase(`/articles/${post.slug}/`)}>{post.data.title}</a></h2>
        <p>{post.data.description}</p>
        <div class="chips">
          {post.data.tags.map((tag) => <a href={withBase(`/articles/tag/${encodeURIComponent(tag)}/`)}>{tag}</a>)}
        </div>
      </div>
      <time datetime={post.data.date.toISOString()}>
        {post.data.date.toISOString().slice(0, 10)}
        <span>阅读约 {post.data.minutes} 分钟</span>
      </time>
    </article>
  ))}
</div>
