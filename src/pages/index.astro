---
import { getCollection } from 'astro:content';
import ProjectCard from '../components/ProjectCard.astro';
import { categoryMetaList } from '../data/categories';
import SiteLayout from '../layouts/SiteLayout.astro';
import { projects } from '../data/projects';
import { withBase } from '../utils/paths';

const posts = (await getCollection('posts'))
  .filter((post) => !post.data.draft && !post.data.private)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featuredPost = posts.find((post) => post.data.featured) ?? posts[0];
const sidePosts = posts.filter((post) => post.id !== featuredPost.id).slice(0, 3);
const categoryLabels = ['Life', 'Do', 'Learn', 'Lab'];
---

<SiteLayout active="home">
  <main class="page-content">
    <section class="hero-grid">
      <div>
        <p class="eyebrow">生活观察 · 实践复盘 · 系统教程</p>
        <h1>记录生活判断、工具实践与系统学习的个人博客</h1>
        <p class="hero-lead">
          这里不是企业官网，而是一张持续更新的个人工作台：沉淀生活里的判断过程、真实项目里的技术踩坑、Agent 工作流和文章视觉实验。
        </p>
        <div class="hero-actions">
          <a class="button primary" href={withBase('/articles/')}>开始阅读</a>
          <a class="button" href={withBase('/projects/')}>查看项目记录</a>
        </div>
        <div class="stats-row" aria-label="站点统计">
          <span><b>{posts.length}</b>公开文章</span>
          <span><b>{projects.length}</b>项目复盘</span>
          <span><b>4</b>主要主题</span>
        </div>
      </div>
      <aside class="terminal-panel" aria-label="自动化工作台伪代码示意">
        <div class="terminal-head">
          <i class="dot red"></i>
          <i class="dot yellow"></i>
          <i class="dot green"></i>
          <span>automation/workbench.py</span>
        </div>
        <div class="terminal-body">
          <pre class="hero-code"><code><span class="comment"># automation/workbench.py</span>

<span class="keyword">from</span> agent <span class="keyword">import</span> run_agent
<span class="keyword">from</span> rpa <span class="keyword">import</span> run_flow
<span class="keyword">from</span> notes <span class="keyword">import</span> publish

TODAY = [<span class="string">"pricing"</span>, <span class="string">"stock"</span>, <span class="string">"reviews"</span>]

<span class="keyword">def</span> <span class="function">workbench</span>():
    <span class="keyword">for</span> task <span class="keyword">in</span> TODAY:
        result = run_agent(task)
        publish(run_flow(result))

    <span class="keyword">return</span> <span class="string">"notes synced"</span></code></pre>
        </div>
      </aside>
    </section>

    <section class="section-block">
      <div class="section-head">
        <div>
          <h2>从这些方向开始</h2>
          <p>按长期内容主题组织，避免首页变成杂乱文章流。</p>
        </div>
        <a href={withBase('/articles/')}>全部主题</a>
      </div>
      <div class="topic-grid">
        {categoryMetaList.map((category, index) => (
          <a class="topic-card" href={withBase(`/articles/category/${encodeURIComponent(category.name)}/`)}>
            <span>{categoryLabels[index]}</span>
            <h3>{category.name}</h3>
            <p>{category.description.split('\n')[0]}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="section-block">
      <div class="section-head">
        <div>
          <h2>精选文章</h2>
          <p>用少量高质量内容建立第一印象。</p>
        </div>
        <a href={withBase('/articles/')}>查看文章库</a>
      </div>
      <div class="feature-grid">
        <article class="featured-card">
          <span class="pill">精选 · {featuredPost.data.category}</span>
          <h3><a href={withBase(`/articles/${featuredPost.slug}/`)}>{featuredPost.data.title}</a></h3>
          <p>{featuredPost.data.description}</p>
          <div class="meta-row">
            <span>阅读约 {featuredPost.data.minutes} 分钟</span>
            <span>{featuredPost.data.date.toISOString().slice(0, 10)}</span>
            <span>{featuredPost.data.tags[0]}</span>
          </div>
          <pre class="code-preview"><code>// readable first, abstraction later
agent.run(task)
if result.needs_review:
  notify_user(result.summary)</code></pre>
        </article>
        <div class="article-row-list">
          {sidePosts.map((post) => (
            <article>
              <small>{post.data.category}</small>
              <h3><a href={withBase(`/articles/${post.slug}/`)}>{post.data.title}</a></h3>
              <p>{post.data.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section-block">
      <div class="section-head">
        <div>
          <h2>项目记录</h2>
          <p>用 case study 的方式展示能力，不做夸张作品集。</p>
        </div>
        <a href={withBase('/projects/')}>全部项目</a>
      </div>
      <div class="project-grid">
        {projects.slice(0, 3).map((project, index) => <ProjectCard project={project} index={index} />)}
      </div>
    </section>
  </main>
</SiteLayout>
