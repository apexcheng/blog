---
import { getCollection } from 'astro:content';
import ProjectCard from '../components/ProjectCard.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { projects } from '../data/projects';
import { withBase } from '../utils/paths';

const posts = (await getCollection('posts'))
  .filter((post) => !post.data.draft && !post.data.private)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featuredPost = posts.find((post) => post.data.featured) ?? posts[0];
const sidePosts = posts.filter((post) => post.id !== featuredPost.id).slice(0, 3);
---

<SiteLayout active="home">
  <main class="page-content">
    <section class="hero-grid">
      <div>
        <p class="eyebrow">AI 自动化 · RPA · 工程笔记</p>
        <h1>记录电商自动化、AI Agent 与编程实践的个人技术博客</h1>
        <p class="hero-lead">
          这里不是企业官网，而是一张持续更新的个人工作台：沉淀电商运营自动化、RPA、表格处理、Agent 工作流、流程图和踩坑复盘。
        </p>
        <div class="hero-actions">
          <a class="button primary" href={withBase('/articles/')}>开始阅读</a>
          <a class="button" href={withBase('/projects/')}>查看项目记录</a>
        </div>
        <div class="stats-row" aria-label="站点统计">
          <span><b>{posts.length}</b>技术文章</span>
          <span><b>{projects.length}</b>项目复盘</span>
          <span><b>4</b>主要主题</span>
        </div>
      </div>
      <aside class="terminal-panel" aria-label="自动化工作台伪代码示意">
        <div class="terminal-head">
          <i class="dot red"></i>
          <i class="dot yellow"></i>
          <i class="dot green"></i>
          <span>automation/workbench.py</span>
        </div>
        <div class="terminal-body">
          <pre class="hero-code"><code><span class="comment"># automation/workbench.py</span>

<span class="keyword">from</span> agent <span class="keyword">import</span> analyze_task
<span class="keyword">from</span> rpa <span class="keyword">import</span> run_flow
<span class="keyword">from</span> sheet <span class="keyword">import</span> update_report
<span class="keyword">from</span> notify <span class="keyword">import</span> send_dingtalk

WORKSPACE = {'{'}
    <span class="string">"focus"</span>: [<span class="string">"AI Agent"</span>, <span class="string">"RPA"</span>, <span class="string">"data workflow"</span>],
    <span class="string">"topics"</span>: [<span class="string">"pricing"</span>, <span class="string">"inventory"</span>, <span class="string">"reviews"</span>, <span class="string">"automation"</span>],
{'}'}

<span class="keyword">def</span> <span class="function">daily_pipeline</span>():
    tasks = [<span class="string">"collect"</span>, <span class="string">"analyze"</span>, <span class="string">"execute"</span>, <span class="string">"sync"</span>]

    <span class="keyword">for</span> task <span class="keyword">in</span> tasks:
        result = analyze_task(task)
        run_flow(result)

    update_report(<span class="string">"ops_dashboard"</span>)
    send_dingtalk(<span class="string">"workflow synced"</span>)
    <span class="keyword">return</span> <span class="string">"notes published"</span></code></pre>
        </div>
      </aside>
    </section>

    <section class="section-block">
      <div class="section-head">
        <div>
          <h2>从这些方向开始</h2>
          <p>按长期内容主题组织，避免首页变成杂乱文章流。</p>
        </div>
        <a href={withBase('/articles/')}>全部主题</a>
      </div>
      <div class="topic-grid">
        <a class="topic-card" href={withBase('/articles/category/AI%20Agent/')}><span>AI</span><h3>AI Agent</h3><p>Agent 工作流、提示词、工具调用和 AI 应用实践。</p></a>
        <a class="topic-card" href={withBase('/articles/category/%E5%BD%B1%E5%88%80RPA/')}><span>RP</span><h3>影刀RPA</h3><p>影刀流程、网页自动化、选择器定位和效率工具。</p></a>
        <a class="topic-card" href={withBase('/articles/category/Skill/')}><span>SK</span><h3>Skill</h3><p>可复用的开发技能、提示词规范和内容编写方法。</p></a>
        <a class="topic-card" href={withBase('/articles/category/%E6%95%B0%E6%8D%AE%E5%A4%84%E7%90%86/')}><span>DT</span><h3>数据处理</h3><p>Excel、WPS、Python 和表格报表自动化实践。</p></a>
      </div>
    </section>

    <section class="section-block">
      <div class="section-head">
        <div>
          <h2>精选文章</h2>
          <p>用少量高质量内容建立第一印象。</p>
        </div>
        <a href={withBase('/articles/')}>查看文章库</a>
      </div>
      <div class="feature-grid">
        <article class="featured-card">
          <span class="pill">精选 · {featuredPost.data.category}</span>
          <h3><a href={withBase(`/articles/${featuredPost.slug}/`)}>{featuredPost.data.title}</a></h3>
          <p>{featuredPost.data.description}</p>
          <div class="meta-row">
            <span>阅读约 {featuredPost.data.minutes} 分钟</span>
            <span>{featuredPost.data.date.toISOString().slice(0, 10)}</span>
            <span>{featuredPost.data.tags[0]}</span>
          </div>
          <pre class="code-preview"><code>// readable first, abstraction later
agent.run(task)
if result.needs_review:
  notify_user(result.summary)</code></pre>
        </article>
        <div class="article-row-list">
          {sidePosts.map((post) => (
            <article>
              <small>{post.data.category}</small>
              <h3><a href={withBase(`/articles/${post.slug}/`)}>{post.data.title}</a></h3>
              <p>{post.data.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section-block">
      <div class="section-head">
        <div>
          <h2>项目记录</h2>
          <p>用 case study 的方式展示能力，不做夸张作品集。</p>
        </div>
        <a href={withBase('/projects/')}>全部项目</a>
      </div>
      <div class="project-grid">
        {projects.slice(0, 3).map((project, index) => <ProjectCard project={project} index={index} />)}
      </div>
    </section>
  </main>
</SiteLayout>
