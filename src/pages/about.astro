---
import SiteLayout from '../layouts/SiteLayout.astro';
import { siteMeta } from '../data/site';
import { withBase } from '../utils/paths';
---

<SiteLayout title="关于" active="home">
  <main class="page-content narrow-page">
    <p class="eyebrow">关于</p>
    <h1 class="page-title">关于 {siteMeta.siteName}</h1>
    <p class="page-lead">
      我是黄撑，主要记录电商运营里的自动化实践、AI Agent、RPA、表格处理和编程工具折腾。这个博客用来沉淀工作流、脚本、流程图、项目复盘和踩坑记录。
    </p>
    <p class="content-note">当前站点保持 Astro / MDX 纯静态发布，重点放在文章、项目记录和可复用的实践笔记。</p>
    <div class="hero-actions">
      <a class="button" href={siteMeta.githubUrl}>GitHub</a>
      <a class="button" href={siteMeta.projectUrl}>项目仓库</a>
      <a class="button" href={withBase(siteMeta.rssPath)}>RSS 订阅</a>
      <a class="button" href={withBase('/projects/')}>项目记录</a>
    </div>
  </main>
</SiteLayout>
