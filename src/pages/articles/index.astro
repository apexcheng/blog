---
import { getCollection } from 'astro:content';
import SiteLayout from '../../layouts/SiteLayout.astro';

const posts = (await getCollection('posts'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const categories = ['全部文章', 'AI / Agent', 'RPA / 自动化', '编程笔记', 'Markdown / MDX', '架构图示例'];
---

<SiteLayout title="文章列表" active="articles">
  <main class="page-content two-column-page">
    <aside class="filter-panel">
      <h2>内容分类</h2>
      {categories.map((category, index) => <a class:list={[index === 0 && 'active']} href="/articles/">{category}</a>)}
    </aside>
    <section>
      <p class="eyebrow">Articles</p>
      <h1 class="page-title">文章列表</h1>
      <p class="page-lead">按主题、标签和更新时间组织技术内容。列表页保持轻量，重点是快速扫描标题、摘要和主题。</p>
      <div class="search-placeholder">Search notes, projects, diagrams...</div>
      <div class="article-list">
        {posts.map((post) => (
          <article class="article-list-item">
            <div>
              <small>{post.data.category}</small>
              <h2><a href={`/articles/${post.slug}/`}>{post.data.title}</a></h2>
              <p>{post.data.description}</p>
              <div class="chips">
                {post.data.tags.map((tag) => <span>{tag}</span>)}
              </div>
            </div>
            <time datetime={post.data.date.toISOString()}>
              {post.data.date.toISOString().slice(0, 10)}
              <span>{post.data.minutes} min</span>
            </time>
          </article>
        ))}
      </div>
    </section>
  </main>
</SiteLayout>
